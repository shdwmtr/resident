digraph reclass_dfa {
    rankdir=LR;
    node [shape=circle fontname="Helvetica" fontsize=13 margin=0.15];
    edge [fontname="Helvetica" fontsize=11];

    __start [shape=point width=0.15];
    SCAN    [shape=doublecircle label="SCAN"];
    QK      [label="QUOTED\nKEY"];
    BK      [label="BARE\nKEY"];
    HASH    [label="HASH"];
    MATCH   [shape=doublecircle label="MATCH\n-> emit"];

    __start -> SCAN;

    SCAN -> SCAN [label="[^\"a-zA-Z_]"];
    SCAN -> QK   [label="'\"' + key_start"];
    SCAN -> BK   [label="key_start"];

    QK -> QK   [label="[a-zA-Z0-9_-]"];
    QK -> HASH [label="'\":\\\"'"];
    QK -> SCAN [label="other\n(rewind +1)"];

    BK -> BK   [label="[a-zA-Z0-9_]"];
    BK -> HASH [label="':\\\"'"];
    BK -> SCAN [label="other"];

    HASH -> HASH  [label="[a-zA-Z0-9_-]"];
    HASH -> MATCH [label="'\"'  18≤len≤30\n+ is_css_hash"];
    HASH -> SCAN  [label="'\"'  len out of range\nor is_css_hash"];

    MATCH -> SCAN [label="continue"];
}
